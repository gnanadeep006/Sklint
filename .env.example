# Django
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
RENDER_EXTERNAL_HOSTNAME=
DATABASE_URL=
DJANGO_DB_CONN_MAX_AGE=600
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false

# Google AI / CodeRoast
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
CODEROAST_GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash

# CodeRoast TTS
CODEROAST_TTS_PROVIDER=browser
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_AUDIO_CODEC=mp3
SARVAM_TTS_ENGLISH_SPEAKER=
SARVAM_TTS_HINDI_SPEAKER=
SARVAM_TTS_TELUGU_SPEAKER=

# Optional cross-origin access for the roast endpoint
CORS_ALLOWED_ORIGINS=

# Optional IBM Cloudant asset catalog for CodeRoast
CLOUDANT_ASSETS_ENABLED=false
CLOUDANT_URL=
CLOUDANT_DATABASE=coderoast_assets
CLOUDANT_USERNAME=
CLOUDANT_PASSWORD=
CLOUDANT_BEARER_TOKEN=
CLOUDANT_ASSET_GROUP=coderoast

# IBM App ID
APPID_REQUIRE_LOGIN=false
APPID_PROTECTED_PATH_PREFIXES=/,/about/,/projects/,/contact/
APPID_EXEMPT_PATH_PREFIXES=
APPID_CLIENT_ID=
APPID_CLIENT_SECRET=
APPID_DISCOVERY_ENDPOINT=
APPID_OAUTH_SERVER_URL=
APPID_SERVICE_ENDPOINT=
APPID_TENANT_ID=
APPID_MANAGEMENT_URL=
APPID_SCOPE=openid email profile
